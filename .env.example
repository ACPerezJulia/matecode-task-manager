# Firebase (frontend — prefijo VITE_ obligatorio para que Vite lo exponga al cliente)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# AWS SES (solo serverless — sin prefijo VITE_, nunca llega al cliente)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
SES_FROM_EMAIL=

# Gemini (solo serverless — sin prefijo VITE_, nunca llega al cliente)
GEMINI_API_KEY=
